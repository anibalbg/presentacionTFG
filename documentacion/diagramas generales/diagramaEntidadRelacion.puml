@startuml
title Diagrama entidad-relación del sistema

skinparam shadowing false
skinparam linetype ortho
hide circle

top to bottom direction

entity "Campo" as Campo {
  * id_campo : entero <<PK>>
  --
  nombre : texto
  ubicacion : texto
}

entity "Hoyo" as Hoyo {
  * id_hoyo : entero <<PK>>
  --
  id_campo : entero <<FK>>
  numero : entero
  par : entero
}

entity "Camara" as Camara {
  * id_camara : entero <<PK>>
  --
  id_hoyo : entero <<FK>>
  nombre : texto
  rol : texto
  activo : booleano
}

entity "Usuario" as Usuario {
  * id_usuario : entero <<PK>>
  --
  nombre_usuario : texto
  email : texto
  contrasena_hash : texto
  fecha_registro : fecha/hora
  activo : booleano
  tipo_usuario : texto
}

entity "SesionCaptura" as SesionCaptura {
  * id_sesion : entero <<PK>>
  --
  id_usuario : entero <<FK>>
  id_hoyo : entero <<FK>>
  id_camara : entero <<FK>>
  fecha_inicio : fecha/hora
  fecha_fin : fecha/hora
  activo : booleano
}

entity "EventoDetectado" as EventoDetectado {
  * id_evento : entero <<PK>>
  --
  id_sesion : entero <<FK>>
  instante_deteccion : fecha/hora
  tipo_evento : texto
  valido : booleano
  confianza : decimal
}

entity "Clip" as Clip {
  * id_clip : entero <<PK>>
  --
  id_usuario : entero <<FK>>
  id_hoyo : entero <<FK>>
  id_evento : entero <<FK nullable>>
  archivo : texto
  fecha_creacion : fecha/hora
  favorito : booleano
  fecha_expiracion : fecha/hora
}

Campo ||--o{ Hoyo : contiene

Hoyo ||--o{ Camara : tiene
Hoyo ||--o{ SesionCaptura : contextualiza
Hoyo ||--o{ Clip : se_produce_en

Camara ||--o{ SesionCaptura : inicia_contexto

Usuario ||--o{ SesionCaptura : activa
Usuario ||--o{ Clip : posee

SesionCaptura ||--o{ EventoDetectado : registra

EventoDetectado ||--o| Clip : genera

@enduml