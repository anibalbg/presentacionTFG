@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false

actor Usuario
actor Jugador
actor Administrador

Usuario <|-- Jugador
Usuario <|-- Administrador

rectangle "Sistema automatizado de captura de golpes en golf" {

  usecase "Login" as UC1
  usecase "Escanear código QR\ndel hoyo" as UC2
  usecase "Consultar clips\ngenerados" as UC3
  usecase "Marcar/Desmarcar clip\ncomo favorito" as UC4
  usecase "Consultar estadísticas\npersonales" as UC5

  usecase "Gestionar clips\nregistrados" as UC6
  usecase "Consultar usuarios\ndel sistema" as UC7
  usecase "Gestionar usuarios\ndel sistema" as UC8
  usecase "Consultar estadísticas\nglobales del sistema" as UC9

}

Jugador --> UC1
Jugador --> UC3
Administrador --> UC1
Administrador --> UC3

Jugador --> UC2
Jugador --> UC4
Jugador --> UC5

Administrador --> UC6
Administrador --> UC7
Administrador --> UC8
Administrador --> UC9

@enduml